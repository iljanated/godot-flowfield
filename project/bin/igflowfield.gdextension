[configuration]

entry_symbol = "flowfield_library_init"
compatibility_minimum = "4.1"
reloadable = true

[libraries]

macos.debug = "./libigflowfield.macos.template_debug.dylib"
macos.release = "./libigflowfield.macos.template_release.dylib"
windows.debug.x86_32 = "./igflowfield.windows.template_debug.x86_32.dll"
windows.release.x86_32 = "./igflowfield.windows.template_release.x86_32.dll"
windows.debug.x86_64 = "./igflowfield.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "./igflowfield.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "./libigflowfield.linux.template_debug.x86_64.so"
linux.release.x86_64 = "./libigflowfield.linux.template_release.x86_64.so"
linux.debug.arm64 = "./libigflowfield.linux.template_debug.arm64.so"
linux.release.arm64 = "./libigflowfield.linux.template_release.arm64.so"
linux.debug.rv64 = "./libigflowfield.linux.template_debug.rv64.so"
linux.release.rv64 = "./libigflowfield.linux.template_release.rv64.so"